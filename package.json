{
  "name": "markdown-studio",
  "version": "0.2.1",
  "description": "Desktopowy edytor i podgląd Markdown dla Windows z eksportem PDF, HTML i DOCX.",
  "main": "dist-electron/main/main.js",
  "author": "Marek",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zetmar-collab/markdown-studio.git"
  },
  "homepage": "https://github.com/zetmar-collab/markdown-studio#readme",
  "bugs": {
    "url": "https://github.com/zetmar-collab/markdown-studio/issues"
  },
  "type": "module",
  "scripts": {
    "icon": "node scripts/make-icon.mjs",
    "predev": "npm run icon",
    "prebuild": "npm run icon",
    "dev": "concurrently -k \"vite\" \"npm:dev:electron\"",
    "dev:electron": "wait-on http://localhost:5173 && npm run build:electron && electron .",
    "build": "npm run typecheck && vite build && npm run build:electron",
    "build:electron": "node scripts/clean-electron-out.mjs && tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dist": "npm run dist:all",
    "dist:setup": "node scripts/stop-running-app.mjs && npm run build && electron-builder --win nsis --publish never",
    "dist:portable": "node scripts/stop-running-app.mjs && npm run build && electron-builder --win portable --publish never",
    "dist:all": "node scripts/stop-running-app.mjs && npm run build && electron-builder --win nsis portable --publish never"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.4.0",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.8",
    "@uiw/react-codemirror": "^4.25.3",
    "highlight.js": "^11.11.1",
    "html-to-docx": "^1.8.0",
    "lucide-react": "^0.561.0",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^2.1.8",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.3"
  },
  "build": {
    "publish": null,
    "appId": "pl.marek.markdownstudio",
    "productName": "Markdown Studio",
    "icon": "build/icon.ico",
    "directories": {
      "output": "out/pack"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "build/icon.ico"
      },
      {
        "from": "build/icon.png",
        "to": "build/icon.png"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "Markdown-Studio-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "Markdown-Studio-${version}-Portable-${arch}.exe"
    },
    "fileAssociations": [
      {
        "ext": "md",
        "name": "MarkdownStudio",
        "description": "Dokument Markdown",
        "role": "Editor"
      }
    ],
    "nsis": {
      "artifactName": "Markdown-Studio-${version}-Setup-${arch}.exe",
      "guid": "8f4c2a1b-9e3d-4f5a-b6c7-1d2e3f4a5b6c",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Markdown Studio",
      "runAfterFinish": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "uninstallDisplayName": "Markdown Studio",
      "perMachine": false,
      "allowElevation": true,
      "installerLanguages": ["pl_PL", "en_US"]
    }
  }
}
